{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "codex-skin-studio://structured-theme/v4",
  "title": "Codex Skin Studio structured Open design",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "targetThemeId",
    "identity",
    "palette",
    "composition",
    "navigation",
    "controls",
    "cards",
    "landing",
    "flair",
    "stagecraft",
    "composer",
    "fields",
    "overlays",
    "motion"
  ],
  "properties": {
    "schemaVersion": { "type": "integer", "enum": [4] },
    "targetThemeId": { "type": ["string", "null"], "maxLength": 120 },
    "identity": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "concept", "keywords"],
      "properties": {
        "name": { "type": "string", "minLength": 1, "maxLength": 60 },
        "concept": { "type": "string", "minLength": 1, "maxLength": 180 },
        "keywords": {
          "type": "array",
          "minItems": 1,
          "maxItems": 6,
          "items": { "type": "string", "minLength": 1, "maxLength": 24 }
        }
      }
    },
    "palette": {
      "type": "object",
      "additionalProperties": false,
      "required": ["surfaceHue", "accentHue", "accentHueOffset", "accentChromaScale", "neutralChromaScale", "surfaceContrast", "surfaceTint"],
      "properties": {
        "surfaceHue": { "type": ["number", "null"], "minimum": 0, "maximum": 360 },
        "accentHue": { "type": ["number", "null"], "minimum": 0, "maximum": 360 },
        "accentHueOffset": { "type": "number", "minimum": -45, "maximum": 45 },
        "accentChromaScale": { "type": "number", "minimum": 0.4, "maximum": 2.2 },
        "neutralChromaScale": { "type": "number", "minimum": 0.4, "maximum": 2 },
        "surfaceContrast": { "type": "number", "minimum": 0.6, "maximum": 1.5 },
        "surfaceTint": { "type": "number", "minimum": 0, "maximum": 0.6 }
      }
    },
    "composition": {
      "type": "object",
      "additionalProperties": false,
      "required": ["layout", "canvasMode", "imageFit", "artTreatment", "imageScale", "wash", "sidebarImage", "titlebarImage"],
      "properties": {
        "layout": { "type": "string", "enum": ["full-bleed", "sidebar-focus", "center-stage", "editorial-split"] },
        "canvasMode": { "type": "string", "enum": ["seamless", "layered"] },
        "imageFit": { "type": "string", "enum": ["cover", "adaptive"] },
        "artTreatment": {
          "type": "string",
          "enum": ["natural"],
          "description": "Preserves the source image or video tone. Skill-generated UI never color-grades the media."
        },
        "imageScale": { "type": "number", "minimum": 1, "maximum": 1.6 },
        "wash": { "type": "number", "minimum": 0.08, "maximum": 0.85 },
        "sidebarImage": { "type": "number", "minimum": 0.3, "maximum": 1.8 },
        "titlebarImage": { "type": "number", "minimum": 0.3, "maximum": 1.8 }
      }
    },
    "navigation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["style", "active", "radius", "iconRadius", "height", "iconSize", "hoverShift", "fontWeight", "iconTreatment", "iconMotif"],
      "properties": {
        "style": { "type": "string", "enum": ["quiet", "rail", "tiles", "ribbon", "pill", "blocks"] },
        "active": { "type": "string", "enum": ["solid", "tint", "outline", "edge", "glow"] },
        "radius": { "type": "number", "minimum": 0, "maximum": 24 },
        "iconRadius": { "type": "number", "minimum": 0, "maximum": 18 },
        "height": { "type": "number", "minimum": 30, "maximum": 52 },
        "iconSize": { "type": "number", "minimum": 20, "maximum": 34 },
        "hoverShift": { "type": "number", "minimum": 0, "maximum": 8 },
        "fontWeight": { "type": "number", "minimum": 400, "maximum": 800 },
        "iconTreatment": {
          "type": "string",
          "enum": ["native", "outline", "duotone", "glass", "stamp", "cutout"],
          "description": "Material treatment around Codex's native SVG icon. Never replaces or hides the semantic icon."
        },
        "iconMotif": {
          "type": "string",
          "enum": ["none", "orbit", "spark", "wave", "shard", "petal", "circuit"],
          "description": "Small theme-derived graphic motif supporting every native navigation icon. Coordinate it with landing.ornament."
        }
      }
    },
    "controls": {
      "type": "object",
      "additionalProperties": false,
      "required": ["radius", "primary", "secondary", "hoverLift", "pressScale"],
      "properties": {
        "radius": { "type": "number", "minimum": 0, "maximum": 24 },
        "primary": { "type": "string", "enum": ["solid", "outline", "soft", "gradient", "glass"] },
        "secondary": { "type": "string", "enum": ["flat", "outline", "soft", "glass"] },
        "hoverLift": { "type": "number", "minimum": 0, "maximum": 4 },
        "pressScale": { "type": "number", "minimum": 0.9, "maximum": 0.99 }
      }
    },
    "cards": {
      "type": "object",
      "additionalProperties": false,
      "required": ["radius", "borderStrength", "elevation", "treatment"],
      "properties": {
        "radius": { "type": "number", "minimum": 0, "maximum": 28 },
        "borderStrength": { "type": "number", "minimum": 0.1, "maximum": 1 },
        "elevation": { "type": "number", "minimum": 0, "maximum": 1 },
        "treatment": { "type": "string", "enum": ["flat", "layered", "image-tint", "glass", "poster"] }
      }
    },
    "landing": {
      "type": "object",
      "additionalProperties": false,
      "required": ["layout", "headlineScale", "cardRhythm", "cardTreatment", "emphasis", "markStyle", "ornament", "ornamentDensity", "ornamentPlacement"],
      "properties": {
        "layout": { "type": "string", "enum": ["centered", "editorial", "poster-hero"] },
        "headlineScale": { "type": "number", "minimum": 0.9, "maximum": 2.2 },
        "cardRhythm": { "type": "string", "enum": ["even", "staggered", "cascade"] },
        "cardTreatment": { "type": "string", "enum": ["solid", "tinted", "image-strip", "poster", "glass"] },
        "emphasis": { "type": "number", "minimum": 0.2, "maximum": 1.2 },
        "markStyle": {
          "type": "string",
          "enum": ["native", "medallion", "portal", "cutout", "signal"],
          "description": "Theme treatment for the native Codex home mark; its SVG remains visible."
        },
        "ornament": {
          "type": "string",
          "enum": ["none", "orbit", "spark", "wave", "shard", "petal", "circuit"],
          "description": "Theme-generated, non-interactive home decoration. Prefer the same family as navigation.iconMotif."
        },
        "ornamentDensity": { "type": "number", "minimum": 0, "maximum": 1 },
        "ornamentPlacement": { "type": "string", "enum": ["corners", "halo", "edges"] }
      }
    },
    "flair": {
      "type": "object",
      "additionalProperties": false,
      "required": ["tilt", "pattern", "patternStrength", "headlineGradient"],
      "properties": {
        "tilt": { "type": "number", "minimum": -3, "maximum": 3 },
        "pattern": { "type": "string", "enum": ["none", "dots", "stripes", "grid", "checker"] },
        "patternStrength": { "type": "number", "minimum": 0, "maximum": 0.5 },
        "headlineGradient": { "type": "boolean" }
      }
    },
    "stagecraft": {
      "type": "object",
      "additionalProperties": false,
      "required": ["archetype", "axis", "typeVoice", "keywordMode", "frame", "scaleJump", "bleed"],
      "properties": {
        "archetype": {
          "type": "string",
          "enum": ["none", "editorial-collision", "cinematic-portal", "kinetic-totem", "analog-broadcast", "surreal-collage", "architectural-grid"],
          "description": "Cross-region composition archetype. It reshapes home layout, navigation rhythm, titlebar framing, and card choreography as one scene."
        },
        "axis": {
          "type": "string",
          "enum": ["horizontal", "diagonal", "vertical", "radial"],
          "description": "Dominant reading direction for the stage, independent from the source image focal point."
        },
        "typeVoice": {
          "type": "string",
          "enum": ["native", "editorial", "condensed", "industrial", "soft"],
          "description": "Local typographic voice for home display text and generated theme words; body copy remains native."
        },
        "keywordMode": {
          "type": "string",
          "enum": ["none", "labels", "oversized", "ticker", "index"],
          "description": "Uses the safe identity name and keywords as non-interactive visual material on the home stage."
        },
        "frame": {
          "type": "string",
          "enum": ["none", "crop", "film", "torn", "double"],
          "description": "Graphic frame language for the home stage, rendered without external assets."
        },
        "scaleJump": { "type": "number", "minimum": 1, "maximum": 3 },
        "bleed": { "type": "number", "minimum": 0, "maximum": 1 }
      }
    },
    "composer": {
      "type": "object",
      "additionalProperties": false,
      "required": ["radius", "controlRadius", "borderStrength", "imageBlend"],
      "properties": {
        "radius": { "type": "number", "minimum": 0, "maximum": 34 },
        "controlRadius": { "type": "number", "minimum": 0, "maximum": 22 },
        "borderStrength": { "type": "number", "minimum": 0.15, "maximum": 1 },
        "imageBlend": { "type": "number", "minimum": 0.05, "maximum": 0.85 }
      }
    },
    "fields": {
      "type": "object",
      "additionalProperties": false,
      "required": ["radius"],
      "properties": {
        "radius": { "type": "number", "minimum": 0, "maximum": 22 }
      }
    },
    "overlays": {
      "type": "object",
      "additionalProperties": false,
      "required": ["radius"],
      "properties": {
        "radius": { "type": "number", "minimum": 0, "maximum": 28 }
      }
    },
    "motion": {
      "type": "object",
      "additionalProperties": false,
      "required": ["duration", "easing"],
      "properties": {
        "duration": { "type": "number", "minimum": 90, "maximum": 420 },
        "easing": { "type": "string", "enum": ["precise", "soft", "snappy", "bouncy"] }
      }
    }
  }
}
